{
  "$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useExhaustiveDependencies": "error",
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "style": {
        "useNamingConvention": "warn",
        "useConst": "error",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "warn",
        "noArrayIndexKey": "warn"
      },
      "performance": {
        "noBarrelFile": "off"
      },
      "a11y": {
        "useButtonType": "warn",
        "noAriaUnsupportedElements": "warn",
        "useAriaPropsForRole": "warn",
        "noRedundantRoles": "warn",
        "noLabelWithoutControl": "warn",
        "useValidAriaProps": "warn",
        "noAriaHiddenOnFocusable": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    }
  },
  "files": {
    "includes": [
      "src/**",
      "*.json",
      "*.config.ts",
      "*.config.js",
      "!!dist/**",
      "!!node_modules/**",
      "!src/generated/**",
      "!**/*.lite.tsx",
      "!!coverage/**",
      "!!playwright-report/**",
      "!!.storybook/**"
    ]
  }
}
