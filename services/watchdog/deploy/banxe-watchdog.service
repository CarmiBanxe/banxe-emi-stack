[Unit]
Description=Banxe Repair Brigade Watchdog
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mmber
WorkingDirectory=/home/mmber/banxe-emi-stack
ExecStart=/home/mmber/banxe-emi-stack/.venv/bin/python -m services.watchdog.watchdog
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=banxe-watchdog

[Install]
WantedBy=multi-user.target
