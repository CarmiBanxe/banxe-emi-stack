      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [520, 300]
    },
    {
      "parameters": {
        "functionCode": "const listName = $json.list_name || 'unknown';\nconst eventType = $json.event_type || 'list_updated';\nconst text = `Watchman list update\\nType: ${eventType}\\nList: ${listName}\\nTime: ${$json.timestamp}`;\nreturn [{ json: { text, event_type: eventType, list_name: listName, timestamp: $json.timestamp } }];"
      },
      "name": "Build Notification Text",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [780, 300]
    },
    {
      "parameters": {
        "authentication": "headerAuth",
        "requestMethod": "POST",
        "url": "http://banxe-emi-stack:8093/internal/notifications/mlro",
        "jsonParameters": true,
        "options": {},
        "headerAuth": {
          "name": "X-Internal-Token",
          "value": "={{ $env.INTERNAL_API_TOKEN }}"
        },
        "bodyParametersJson": "={\"channel\": \"mlro_sanctions\", \"severity\": \"warning\", \"message\": $json[\"text\"], \"source\": \"watchman_list_update\"}"
      },
      "name": "Notify MLRO / Head of FinCrime",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1040, 300]
    }
  ],
