        }
      },
      "name": "HTTP Webhook (from FastAPI)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [260, 300],
      "webhookId": "watchman_list_update"
    },
    {
      "parameters": {
        "functionCode": "return [{ json: {\n  event_type: $json[\"event_type\"],\n  list_name: $json[\"list_name\"] || null,\n  timestamp: $json[\"timestamp\"],\n  details: $json[\"details\"] || {}\n}}];"
      },
