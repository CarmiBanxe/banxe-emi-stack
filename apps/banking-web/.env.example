# Banking Web — SANDBOX environment template
# Copy to .env.local and fill in values. NEVER commit .env.local.

# LiteLLM proxy (banxe-general, running on :4000)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sandbox-key

# Model to use (must be registered in LiteLLM config)
BANKING_MODEL=banxe-general
