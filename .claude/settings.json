      "Bash(python3 -m pytest *)",
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(mypy *)",
      "Bash(alembic revision *)",
      "Bash(alembic revision --autogenerate *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git status -*)",
      "Bash(git diff *)",
      "Bash(git diff -*)",
      "Bash(git log *)",
      "Bash(git log -*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git remote *)",
      "Bash(git tag)",
      "Bash(git tag *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show)",
      "Bash(git -C * show *)",
      "Bash(git -C * branch)",
      "Bash(git -C * branch *)",
      "Bash(git -C * remote *)",
      "Bash(git -C * tag)",
      "Bash(git -C * tag *)",
      "Bash(git -C * add *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * restore *)",
      "Bash(git -C * stash)",
      "Bash(git -C * stash *)",
      "Bash(git push --dry-run *)",
      "Bash(git -C * push --dry-run *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git -C * fetch)",
      "Bash(git -C * fetch *)",
      "Bash(git pull --ff-only)",
      "Bash(git pull --ff-only *)",
      "Bash(git -C * pull --ff-only)",
      "Bash(git -C * pull --ff-only *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose build *)",
      "Bash(docker ps *)",
      "Bash(make *)",
      "Bash(pip install *)",
      "Bash(pip install -r *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(ls -l *)",
      "Bash(ls -la *)",
      "Bash(ls -lah *)",
      "Bash(pwd)",
      "Bash(tree *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(wc -l *)",
      "Bash(find . *)",
      "Bash(find services *)",
      "Bash(find apps *)",
      "Bash(find scripts *)",
      "Bash(find tests *)",
      "Bash(grep -r *)",
      "Bash(grep -R *)",
