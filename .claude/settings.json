{
  "model": "sonnet",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "mcp__guiyon-files__*",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * HEAD:main *)",
      "Bash(git push * HEAD:main)",
      "Bash(git push origin main *)",
      "Bash(git push origin main)",
      "Bash(git push origin master *)",
      "Bash(git push origin master)",
      "Bash(git -C * push --force *)",
      "Bash(git -C * push origin main)",
      "Bash(git -C * push origin main *)",
      "Bash(git -C * push origin master)",
      "Bash(git -C * push origin master *)",
      "Bash(git -C * push * HEAD:main)",
      "Bash(git -C * push * HEAD:main *)",
      "Bash(git -C * push * HEAD:master)",
      "Bash(git -C * push * HEAD:master *)",
      "Bash(git -C * push * main)",
      "Bash(git -C * push * master)",
      "Bash(git -C * push * release/*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(cat .env*)",
      "Bash(alembic upgrade *prod*)",
      "Bash(alembic downgrade *prod*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker push *)",
      "Bash(alembic upgrade *)",
      "Bash(alembic downgrade *)",
      "Bash(psql *)"
    ],
    "allow": [
