      "Bash(cat docker-compose*.yml)",
      "Bash(cat Makefile)",
      "Bash(python3 scripts/*)",
      "Bash(python scripts/*)",
      "Bash(bash scripts/*)",
      "Bash(sh scripts/*)",
      "Bash(make scripts-*)",
      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh run list)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list)",
      "Bash(gh workflow view *)",
      "Bash(gh repo view *)",
