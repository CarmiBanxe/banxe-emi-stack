# banxe-emi-stack — P0 Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# === Midaz CBS ===
MIDAZ_BASE_URL=http://localhost:8095
MIDAZ_ORG_ID=019d6301-32d7-70a1-bc77-0a05379ee510
MIDAZ_LEDGER_ID=019d632f-519e-7865-8a30-3c33991bba9c
MIDAZ_TOKEN=

# === Safeguarding Accounts (ADR-013) ===
SAFEGUARDING_CLIENT_FUNDS_ACCOUNT=019d6332-da7f-752f-b9fd-fa1c6fc777ec
SAFEGUARDING_OPERATIONAL_ACCOUNT=019d6332-f274-709a-b3a7-983bc8745886

# === PostgreSQL (pgAudit target) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=banxe_compliance
POSTGRES_USER=
POSTGRES_PASSWORD=

# === ClickHouse (audit trail) ===
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=banxe
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === n8n Webhook (safeguarding alert) ===
N8N_WEBHOOK_URL=http://localhost:5678/webhook/safeguarding-alert

# === Bank Statements ===
STATEMENT_DIR=/data/banxe/statements
# adorsys PSD2 gateway (Phase 0 - automated statement pull)
# ADORSYS_PSD2_URL=http://localhost:8888
# ADORSYS_BANK_IBAN=

# === Frankfurter FX Rates ===
FRANKFURTER_URL=http://localhost:8080

# === dbt ===
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# === FCA Reporting ===
FCA_REGDATA_URL=https://regdata.fca.org.uk
# FCA_REGDATA_USER=
# FCA_REGDATA_PASSWORD=
FIN060_OUTPUT_DIR=/data/banxe/reports/fin060

# === Reconciliation ===
RECON_THRESHOLD_GBP=1.00
RECON_CURRENCY=GBP
