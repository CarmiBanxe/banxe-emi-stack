# banxe-emi-stack — P0 Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# === Auth (JWT) ===
# At least 32 random bytes: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-in-production
AUTH_TOKEN_TTL_HOURS=24
# MVP dev PIN — replace with per-customer hashed PINs in production
AUTH_DEV_PIN=123456

# === Midaz CBS ===
MIDAZ_BASE_URL=http://localhost:8095
MIDAZ_ORG_ID=019d6301-32d7-70a1-bc77-0a05379ee510
MIDAZ_LEDGER_ID=019d632f-519e-7865-8a30-3c33991bba9c
MIDAZ_TOKEN=

# === Safeguarding Accounts (ADR-013) ===
SAFEGUARDING_CLIENT_FUNDS_ACCOUNT=019d6332-da7f-752f-b9fd-fa1c6fc777ec
SAFEGUARDING_OPERATIONAL_ACCOUNT=019d6332-f274-709a-b3a7-983bc8745886

# === PostgreSQL (pgAudit target) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=banxe_compliance
POSTGRES_USER=
POSTGRES_PASSWORD=

# === ClickHouse (audit trail) ===
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=banxe
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === n8n Webhook (safeguarding alert) ===
N8N_WEBHOOK_URL=http://localhost:5678/webhook/safeguarding-alert

# === Bank Statements ===
STATEMENT_DIR=/data/banxe/statements
# adorsys PSD2 gateway (FA-07 IL-011 — automated CAMT.053 statement pull)
ADORSYS_PSD2_URL=http://localhost:8888
ADORSYS_BANK_IBAN=
# Safeguarding account IBANs (set after bank account opened)
SAFEGUARDING_OPERATIONAL_IBAN=
SAFEGUARDING_CLIENT_FUNDS_IBAN=
# adorsys dedicated postgres (port 5434, DB: adorsys/adorsys_mock)
PSD2_POSTGRES_USER=adorsys
PSD2_POSTGRES_PASSWORD=

# === Frankfurter FX Rates ===
FRANKFURTER_URL=http://localhost:8181   # port 8080 occupied by nginx on GMKtec

# === dbt ===
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# === FCA Reporting ===
FCA_REGDATA_URL=https://regdata.fca.org.uk
# FCA_REGDATA_USER=
# FCA_REGDATA_PASSWORD=
FIN060_OUTPUT_DIR=/data/banxe/reports/fin060

# === Reconciliation ===
RECON_THRESHOLD_GBP=1.00
RECON_CURRENCY=GBP

# Keycloak IAM (BT-003 unblocked)
IAM_ADAPTER=keycloak
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=banxe
KEYCLOAK_CLIENT_ID=banxe-backend
KEYCLOAK_CLIENT_SECRET=<redacted>

# ADR-027 Audit trail durability
CLICKHOUSE_URL=http://192.168.0.72:8123
CLICKHOUSE_DB=banxe
AUDIT_DRY_RUN=false
AUDIT_BUFFER_PATH=/tmp/banxe-audit-buffer.db
# Set to true in production to fail-closed on ClickHouse outage (ADR-027)
AUDIT_FAIL_CLOSED=false

# === OTP Delivery (Sprint 6 — ADR-029) ===
# Twilio Verify v2 (SMS + email OTP delivery)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Note: TWILIO_FROM_NUMBER (Messaging API) is NOT used; Verify v2 uses SERVICE_SID instead.

# SendGrid Mail Send API (email OTP delivery)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=otp-noreply@banxe.com

# === KYC / SumSub (Sprint 7 — ADR-025, [IL-KYC-PROD-01]) ===
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_BASE_URL=https://api.sumsub.com

# === Payments / Modulr Finance (Sprint 8 — ADR-025, [IL-SEPA-PROD-01]) ===
# Modulr sandbox: https://api-sandbox.modulrfinance.com (used when MODULR_SANDBOX=true)
MODULR_API_KEY=your_modulr_api_key
MODULR_API_SECRET=your_modulr_api_secret
MODULR_EUR_ACCOUNT_ID=your_modulr_eur_account_id
# Only needed for production (sandbox=False); defaults to https://api.modulrfinance.com
MODULR_API_URL=https://api.modulrfinance.com

# === PostgreSQL Backup (ADR-029) ===
# Feature flag — set to "true" to enable backup operations
BACKUP_ENABLED=false
BACKUP_PG_HOST=localhost
BACKUP_PG_PORT=5432
BACKUP_PG_USER=banxe
BACKUP_PG_PASSWORD=
BACKUP_DIR=/data/banxe/backups
BACKUP_RETENTION_COUNT=7

# === Offsite Backup Upload (ADR-029 §1) ===
# Feature flag — set to "true" to enable offsite upload of completed backups.
# When disabled, get_offsite_upload_adapter() returns None.
OFFSITE_UPLOAD_ENABLED=false
# Adapter selector: "in_memory" (default, dev/test) or "minio" (deferred —
# raises NotImplementedError until the real MinIO/evo2 integration lands)
OFFSITE_UPLOAD_ADAPTER=in_memory

# === PostgreSQL Restore Drill (ADR-029 §4) ===
# Feature flag — set to "true" to enable weekly restore-drill operations
RESTORE_DRILL_ENABLED=false
# Table used by the row-count validation step (ADR-029 §4 default: "cases")
RESTORE_DRILL_VALIDATION_TABLE=cases
# Prefix for the throwaway drill DB (auto-suffixed with instance + epoch)
RESTORE_DRILL_DB_PREFIX=postgres-restore-drill-

# === Secret Rotation (ADR-032) ===
# Feature flag — set to "true" to enable rotation operations
SECRET_ROTATION_ENABLED=false
SECRET_ROTATION_INTERVAL_DAYS=90
# Comma-separated list of env var names to manage
SECRET_ROTATION_MANAGED_KEYS=KC_BOOT_ADMIN_PASSWORD,KC_DB_PASSWORD,AUTH_SECRET_KEY
SECRET_ROTATION_ENV_FILE=.env
