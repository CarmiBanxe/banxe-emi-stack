# infra/chatwoot/.env.example — Chatwoot environment template
# Copy to .env and fill in real values. NEVER commit .env.
# IL-CSB-01 | #108

# Database
CHATWOOT_DB_NAME=chatwoot_production
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=changeme_strong_password

# Redis
CHATWOOT_REDIS_PASSWORD=changeme_redis_password

# Rails
CHATWOOT_SECRET_KEY_BASE=changeme_64_char_hex_secret_key_base_here_xxxxxxxxxxxxxxxxxxxx

# SMTP (FCA DISP 1.3 — required for customer notifications)
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.your_sendgrid_key
SMTP_AUTHENTICATION=plain
MAILER_SENDER_EMAIL=support@banxe.com

# Port
CHATWOOT_PORT=3010

# BANXE API (for webhook integration)
BANXE_API_BASE=http://localhost:8000
