# Keycloak realm banxe-emi — operator-supplied env values
# ADR-017 / I-34 / INV-IAM-01 | FCA CASS 15
#
# DO NOT put real secrets here.
# Real values live in operator vault and are exported to shell (or written to
# ~/.banxe/keycloak.env with chmod 0600) before running docker compose or scripts.
# Pre-commit hook iam-no-direct-creds will block any commit with real values.

# Keycloak bootstrap admin (used only for initial setup via GATE-A)
KC_BOOT_ADMIN=__SET_IN_OPERATOR_ENV__
KC_BOOT_ADMIN_PASSWORD=__SET_IN_OPERATOR_ENV__

# Keycloak database password (shared between KC and its postgres)
KC_DB_PASSWORD=__SET_IN_OPERATOR_ENV__

# Keycloak base URL (used by healthcheck and kcadm scripts)
KC_BASE_URL=http://evo1:8180

# Per-service client_secret values (provision via scripts/provision-clients.sh after GATE-A)
# Never commit real values. Rotate every 90 days per I-34 / ADR-017 §5.
KC_CLIENT_SECRET_BANXE_COMPLIANCE_API=__SET_IN_OPERATOR_ENV__
KC_CLIENT_SECRET_BANXE_DASHBOARD=__SET_IN_OPERATOR_ENV__
KC_CLIENT_SECRET_DEEP_SEARCH=__SET_IN_OPERATOR_ENV__
KC_CLIENT_SECRET_DRIVE_WATCHER=__SET_IN_OPERATOR_ENV__
