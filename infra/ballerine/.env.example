# infra/ballerine/.env.example
# Copy to .env and fill in secrets before deploying.
# DO NOT commit .env to git — secrets only.

# PostgreSQL
BALLERINE_DB_USER=ballerine
BALLERINE_DB_PASSWORD=changeme_strong_password
BALLERINE_DB_NAME=ballerine

# JWT / Session (generate with: openssl rand -hex 32)
BALLERINE_JWT_SECRET=
BALLERINE_SESSION_SECRET=

# Banxe stack env vars (set in banxe-emi-stack/.env after deploy):
# KYC_ADAPTER=ballerine
# BALLERINE_URL=http://gmktec:3000
# BALLERINE_KYC_DEFINITION_ID=banxe-individual-kyc-v1
# BALLERINE_KYB_DEFINITION_ID=banxe-business-kyb-v1
# BALLERINE_API_TOKEN=           # optional bearer token for API auth
