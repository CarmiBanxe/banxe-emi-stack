# .env.compliance-memory.example
# BANXE AI Bank — Compliance Memory Stack (SANDBOX)
# LEGION ONLY | Copy to .env.compliance-memory and fill in values
# ⚠️ НЕ коммитить .env.compliance-memory с реальными значениями!

# ──────────────────────────────────────────────
# Neo4j
# ──────────────────────────────────────────────
# Format: username/password
# ОБЯЗАТЕЛЬНО изменить пароль перед первым запуском!
NEO4J_AUTH=neo4j/CHANGEME_USE_STRONG_PASSWORD_HERE
NEO4J_PASSWORD=CHANGEME_USE_STRONG_PASSWORD_HERE

# ──────────────────────────────────────────────
# LLM for Graphiti entity extraction
# Option A: OpenAI
# Option B: Local LLM (LiteLLM / Ollama compatible)
# ──────────────────────────────────────────────
GRAPHITI_LLM_API_KEY=CHANGEME_sk-xxxx

# OpenAI (default):
GRAPHITI_LLM_BASE_URL=https://api.openai.com/v1
GRAPHITI_LLM_MODEL=gpt-4o-mini

# Local LLM alternative (uncomment to use):
# GRAPHITI_LLM_BASE_URL=http://host.docker.internal:11434/v1
# GRAPHITI_LLM_MODEL=llama3.2:3b
# GRAPHITI_LLM_API_KEY=ollama

# ──────────────────────────────────────────────
# Embedding model (for semantic search)
# Uses same API key as LLM unless overridden
# ──────────────────────────────────────────────
GRAPHITI_EMBEDDER_API_KEY=${GRAPHITI_LLM_API_KEY}
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small

# Local embedder alternative:
# GRAPHITI_EMBEDDER_MODEL=nomic-embed-text
# GRAPHITI_EMBEDDER_API_KEY=ollama

# ──────────────────────────────────────────────
# Service config
# ──────────────────────────────────────────────
LOG_LEVEL=INFO
SANDBOX_MODE=true

# ──────────────────────────────────────────────
# EVO1 DEPLOYMENT NOTES (operator fills before evo1 deploy)
# ──────────────────────────────────────────────
# EVO1_NEO4J_AUTH=neo4j/<evo1_strong_password>
# EVO1_GRAPHITI_LLM_API_KEY=<evo1_api_key>
# EVO1_GRAPHITI_LLM_BASE_URL=<evo1_LLM_endpoint>
# EVO1_HOST_IP=<evo1_machine_IP>
