      "title": "Recent Generations",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT event_time, component_id, framework, agent_type, tokens_used, latency_ms, qa_similarity, qa_passed, model_used FROM banxe.design_pipeline_events ORDER BY event_time DESC LIMIT 50",
