{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "BANXE ClickHouse datasource (grafana-clickhouse-datasource)",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-clickhouse-datasource",
      "name": "ClickHouse",
      "version": "4.0.0"
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FCA CASS 7.15 / CASS 15.12 — Daily Safeguarding Reconciliation Monitor",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Daily Reconciliation Status",
      "description": "Stacked bar: MATCHED / DISCREPANCY / PENDING per day (FCA CASS 7.15)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "orientation": "auto",
        "stacking": "normal",
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "MATCHED" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DISCREPANCY" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "PENDING" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FFB357", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT recon_date, status, count() as count FROM banxe.safeguarding_events WHERE recon_date >= today() - 30 GROUP BY recon_date, status ORDER BY recon_date ASC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Discrepancy Amount Trend",
      "description": "Daily total discrepancy amount trend — rising trend triggers CASS 15.12 breach check",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "currencyGBP",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT recon_date as time, account_id, sum(abs(discrepancy)) as total_discrepancy FROM banxe.safeguarding_events WHERE status = 'DISCREPANCY' AND recon_date >= today() - 30 GROUP BY recon_date, account_id ORDER BY recon_date ASC",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Safeguarding Breaches",
      "description": "Breaches detected by BreachDetector (CASS 15.12 — notify FCA within 1 business day)",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "discrepancy" },
            "properties": [
              { "id": "unit", "value": "currencyGBP" },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "orange", "value": 1000 },
                    { "color": "red", "value": 10000 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "days_outstanding" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 3 },
                    { "color": "red", "value": 7 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "days_outstanding", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT detected_at, recon_date, account_id, account_type, currency, discrepancy, days_outstanding, reported_to_fca FROM banxe.safeguarding_breaches ORDER BY detected_at DESC LIMIT 50",
          "format": "table",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Days Since Last MATCHED",
      "description": "How many days since last successful MATCHED reconciliation — 0 is healthy",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 7 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT dateDiff('day', max(recon_date), today()) as days_since_matched FROM banxe.safeguarding_events WHERE status = 'MATCHED'",
          "format": "table",
          "refId": "D"
        }
      ]
    },
    {
      "id": 5,
      "title": "Breach History Timeline",
      "description": "Historical breach timeline — shows escalation pattern (CASS 15.12 FCA reporting)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#F2495C", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "always",
            "pointSize": 6
          },
          "unit": "currencyGBP",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT detected_at as time, account_id, discrepancy FROM banxe.safeguarding_breaches WHERE detected_at >= now() - INTERVAL 90 DAY ORDER BY detected_at ASC",
          "format": "time_series",
          "refId": "E"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["banxe", "safeguarding", "fca", "cass7", "cass15", "recon"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "definition": "SELECT DISTINCT account_id FROM banxe.safeguarding_events ORDER BY account_id",
        "hide": 0,
        "includeAll": true,
        "label": "Account",
        "multi": true,
        "name": "account_id",
        "options": [],
        "query": "SELECT DISTINCT account_id FROM banxe.safeguarding_events ORDER BY account_id",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Safeguarding Reconciliation — FCA CASS 7.15 / 15.12",
  "uid": "banxe-safeguarding-recon-v1",
  "version": 1
}
