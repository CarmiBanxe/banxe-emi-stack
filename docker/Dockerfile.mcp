FROM python:3.12-slim

LABEL maintainer="banxe-emi-stack"
LABEL description="BANXE MCP Server — FCA-authorised EMI AI Bank tools"
LABEL il_ref="IL-MCP-01"

WORKDIR /app

# Install system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files first (layer caching)
COPY pyproject.toml ./
COPY requirements.txt ./

# Install Python deps
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY banxe_mcp/ ./banxe_mcp/
COPY services/ ./services/
COPY agents/ ./agents/

# SSE transport listens on 8100
EXPOSE 8100

# Default: SSE transport for web clients
# Override with: docker run ... python -m banxe_mcp --transport stdio
CMD ["python", "-m", "banxe_mcp", "--transport", "sse"]
